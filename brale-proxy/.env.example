# Brale API credentials (OAuth2 client credentials)
# Get these from your Brale dashboard: https://dashboard.brale.xyz
BRALE_CLIENT_ID=your_client_id
BRALE_CLIENT_SECRET=your_client_secret

# Partner (parent) Brale account ID (KSUID format).
# This is the top-level KYB-verified account. Managed sub-accounts for
# end users are created under this account automatically.
# Find via: GET https://api.brale.xyz/accounts after authenticating
BRALE_ACCOUNT_ID=your_account_id

# Brale API endpoints (defaults shown — override for custom environments)
BRALE_API_URL=https://api.brale.xyz
BRALE_AUTH_URL=https://auth.brale.xyz

# Server port
PORT=3000

# Transfer type safety allowlist (comma-separated).
# The proxy rejects any transfer whose source or destination transfer_type
# is not in this list. This prevents accidental mainnet transfers.
# Set to "*" to disable the guard (not recommended).
ALLOWED_TRANSFER_TYPES=xion_testnet,ach_debit,ach_credit,same_day_ach_credit,rtp_credit

# SQLite database path for per-user account mappings
DB_PATH=./data/accounts.db
