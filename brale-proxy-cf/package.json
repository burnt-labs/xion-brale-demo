{
  "name": "brale-proxy-cf",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute brale-proxy-db --local --file=migrations/0001_init.sql",
